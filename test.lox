fun makeFilter(min) {
  fun filter(n) {
    if (n < min) {
      return false;
    }
    return true;
  }
  return filter;
}

// This function applies a function to a list of numbers
fun applyToNumbers(f, count) {
  var n = 0;
  while (n < count) {
    if (f(n)) {
      print n;
    }
    n = n + 1;
  }
}

var greaterThanX = makeFilter(89);
var greaterThanY = makeFilter(38);

print "Numbers >= 89:";
applyToNumbers(greaterThanX, 89 + 4);

print "Numbers >= 38:";
applyToNumbers(greaterThanY, 38 + 4);